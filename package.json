{
  "name": "fisqua",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "description": "Collaborative cataloguing and data-management platform for archival materials, built on Cloudflare Workers.",
  "license": "AGPL-3.0-only",
  "author": {
    "name": "Juan Cobo Betancourt",
    "email": "juan@neogranadina.org"
  },
  "contributors": [
    {
      "name": "Archives, Memory, and Preservation Lab, University of California, Santa Barbara"
    },
    {
      "name": "Neogranadina"
    }
  ],
  "homepage": "https://fisqua.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/UCSB-AMPLab/fisqua.git"
  },
  "bugs": {
    "url": "https://github.com/UCSB-AMPLab/fisqua/issues"
  },
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "deploy": "npm run build && wrangler deploy",
    "dev": "react-router dev",
    "postinstall": "npm run cf-typegen",
    "preview": "npm run build && vite preview",
    "import:neogranadina": "npx tsx scripts/import-neogranadina.ts",
    "test": "npm run test:workers && npm run test:node && npm run test:import",
    "test:workers": "vitest run",
    "test:node": "vitest run --config vitest.node.config.ts",
    "test:import": "vitest run --config vitest.import.config.ts",
    "typecheck": "npm run cf-typegen && react-router typegen && tsc -b"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.21",
    "arctic": "^3.7.0",
    "drizzle-orm": "^0.45.1",
    "i18next": "^25.8.17",
    "i18next-browser-languagedetector": "^8.2.1",
    "isbot": "^5.1.31",
    "lucide-react": "^0.577.0",
    "maplibre-gl": "5.24.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.6",
    "react-router": "7.12.0",
    "remix-i18next": "^7.4.2",
    "resend": "^6.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@cloudflare/vite-plugin": "^1.13.7",
    "@cloudflare/vitest-pool-workers": "^0.12.20",
    "@react-router/dev": "7.12.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "mysql2": "^3.22.3",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "wrangler": "^4.40.2",
    "xmllint-wasm": "^5.2.0"
  }
}
